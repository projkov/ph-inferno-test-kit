      "https://fhir.doh.gov.ph/phcore/StructureDefinition/ph-core-practitioner": {
        "first_class_profile": "read"
      },
      "https://fhir.doh.gov.ph/phcore/StructureDefinition/ph-core-practitionerrole": {
        "first_class_profile": "read"
      }
    },
    "resources": {
