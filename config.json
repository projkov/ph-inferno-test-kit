        "label": "Source Code",
        "url": "https://github.com/projkov/ph-inferno-test-kit"
      },
      {
        "label": "Implementation Guide",
        "url": "https://fhir.doh.gov.ph/phcore/ImplementationGuide/fhir.ph.core"
      }
    ]
